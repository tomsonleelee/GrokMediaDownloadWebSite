{
  "redirects": [
    { "source": "/en", "destination": "/", "permanent": true },
    { "source": "/en/index.html", "destination": "/", "permanent": true },
    { "source": "/en/:path*", "destination": "/:path*", "permanent": true },
    { "source": "/zh-TW/index.html", "destination": "/zh-TW/", "permanent": true },
    { "source": "/ja/index.html", "destination": "/ja/", "permanent": true },
    { "source": "/ko/index.html", "destination": "/ko/", "permanent": true },
    { "source": "/index.html", "destination": "/", "permanent": true }
  ],
  "trailingSlash": true,
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/css/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000" }
      ]
    }
  ]
}
